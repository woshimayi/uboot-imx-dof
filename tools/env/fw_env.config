# Configuration file for fw_(printenv/setenv) utility for the i.MX6ULL DOF board.
#
# Layout note (要和 u-boot 的 defconfig + include/configs/mx6ulldof.h 严格对齐):
#   CONFIG_ENV_SIZE          = 0x20000   (一份 env 数据 128KiB, 占一个 erase block)
#   CONFIG_ENV_RANGE         = 0x80000   (4 个 erase block, 用于跳坏块)
#   CONFIG_ENV_OFFSET        = 0x07000000 -> 分区 env_a (mtd6)
#   CONFIG_ENV_OFFSET_REDUND = 0x07080000 -> 分区 env_b (mtd7)
#   NAND erase block         = 0x20000  (128KiB), 这是 "Flash sector size"
#
# fw_env.config 五列含义:
#   MTD device     Device offset   Env. size   Flash sector size   Number of sectors
#
# 注意 mtd 编号要按当前 mtdparts 顺序数 (uboot_a=mtd0, uboot_b=1, kfd_a=2, kfd_b=3,
# tee_a=4, tee_b=5, env_a=6, env_b=7, rootfs_a=8, rootfs_b=9, date=10)。
# 写错 mtd 编号 = 直接破坏其他分区数据, 历史上踩过。

/dev/mtd6		0x0000		0x20000		0x20000		4
/dev/mtd7		0x0000		0x20000		0x20000		4
